<Window x:Class="DPM.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data Pipeline Manager" Height="600" Width="1000"
        Background="#1E1E2E">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Sidebar Panel -->
        <StackPanel Grid.Column="0" Background="#181825">
            <TextBlock Text="🔧 DPM" Foreground="White" FontSize="20"
                       FontWeight="Bold" Margin="20,30,0,30"/>
            <Button Content="📊 Dashboard" Tag="Dashboard"
                    Click="NavButton_Click"
                    Style="{StaticResource NavButtonStyle}"/>
            <Button Content="⚙️ Pipelines" Tag="Pipelines"
                    Click="NavButton_Click"
                    Style="{StaticResource NavButtonStyle}"/>
            <Button Content="📋 Logs" Tag="Logs"
                    Click="NavButton_Click"
                    Style="{StaticResource NavButtonStyle}"/>
            <Button Content="📁 Import Data" Tag="Import"
                    Click="NavButton_Click"
                    Style="{StaticResource NavButtonStyle}"/>
        </StackPanel>
        <!-- Main Content -->
        <Frame x:Name="MainFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>