<Page x:Class="DPM.UI.Views.PipelinesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">
    <StackPanel Margin="30">
        <TextBlock Text="⚙️ Pipelines" Foreground="White"
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        <!-- Add Pipeline -->
        <Border Background="#313244" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Create New Pipeline" Foreground="White"
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBox x:Name="PipelineNameBox" 
                         Background="#45475A" Foreground="White"
                         BorderThickness="0" Padding="10,8"
                         Margin="0,0,0,10"/>
                <TextBox x:Name="PipelineDescBox"
                         Background="#45475A" Foreground="White"
                         BorderThickness="0" Padding="10,8"
                         Margin="0,0,0,10"/>
                <Button Content="➕ Create Pipeline"
                        Background="#89B4FA" Foreground="#1E1E2E"
                        FontWeight="Bold" Padding="15,8"
                        BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Left"
                        Click="CreatePipeline_Click"/>
            </StackPanel>
        </Border>
        <!-- Pipelines List -->
        <DataGrid x:Name="PipelinesGrid"
                  AutoGenerateColumns="False"
                  Background="#313244" Foreground="White"
                  BorderThickness="0" RowBackground="#313244"
                  AlternatingRowBackground="#45475A"
                  GridLinesVisibility="None" IsReadOnly="True">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#181825"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="120"/>
                <DataGridTemplateColumn Header="Actions" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▶ Run"
                                        Background="#A6E3A1" Foreground="#1E1E2E"
                                        FontWeight="Bold" Padding="8,4"
                                        BorderThickness="0" Cursor="Hand"
                                        Margin="0,0,5,0"
                                        Click="RunPipeline_Click"/>
                                <Button Content="🗑 Delete"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        FontWeight="Bold" Padding="8,4"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="DeletePipeline_Click"/>
                                <Button Content="🔍 Detail"
                                        Background="#89B4FA" Foreground="#1E1E2E"
                                        FontWeight="Bold" Padding="8,4"
                                        BorderThickness="0" Cursor="Hand"
                                        Margin="0,0,5,0"
                                        Click="DetailPipeline_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Page>