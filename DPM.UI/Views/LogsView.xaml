<Page x:Class="DPM.UI.Views.LogsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">
    <StackPanel Margin="30">
        <TextBlock Text="📋 Execution Logs" Foreground="White"
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        <DataGrid x:Name="LogsGrid"
                  AutoGenerateColumns="False"
                  Background="#313244" Foreground="White"
                  BorderThickness="0" RowBackground="#313244"
                  AlternatingRowBackground="#45475A"
                  GridLinesVisibility="None" IsReadOnly="True">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#181825"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="100"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="80"/>
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                <DataGridTextColumn Header="Pipeline" Binding="{Binding Pipeline.Name}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Page>