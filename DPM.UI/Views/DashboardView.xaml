<Page x:Class="DPM.UI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">
    <StackPanel Margin="30">
        <TextBlock Text="📊 Dashboard" Foreground="White"
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        <WrapPanel>
            <!-- Card 1 -->
            <Border Background="#313244" CornerRadius="10"
                    Padding="20" Margin="0,0,15,15" Width="200">
                <StackPanel>
                    <TextBlock Text="Total Pipelines" Foreground="#CDD6F4" FontSize="13"/>
                    <TextBlock x:Name="TotalPipelinesText" Text="0"
                               Foreground="White" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <!-- Card 2 -->
            <Border Background="#313244" CornerRadius="10"
                    Padding="20" Margin="0,0,15,15" Width="200">
                <StackPanel>
                    <TextBlock Text="Running" Foreground="#CDD6F4" FontSize="13"/>
                    <TextBlock x:Name="RunningText" Text="0"
                               Foreground="#A6E3A1" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <!-- Card 3 -->
            <Border Background="#313244" CornerRadius="10"
                    Padding="20" Margin="0,0,15,15" Width="200">
                <StackPanel>
                    <TextBlock Text="Failed" Foreground="#CDD6F4" FontSize="13"/>
                    <TextBlock x:Name="FailedText" Text="0"
                               Foreground="#F38BA8" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </WrapPanel>
        <!-- Recent Pipelines -->
        <TextBlock Text="Recent Pipelines" Foreground="White"
                   FontSize="18" FontWeight="Bold" Margin="0,20,0,10"/>
        <DataGrid x:Name="RecentPipelinesGrid"
                  AutoGenerateColumns="False"
                  Background="#313244" Foreground="White"
                  BorderThickness="0" RowBackground="#313244"
                  AlternatingRowBackground="#45475A"
                  GridLinesVisibility="None" IsReadOnly="True">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#181825"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Page>