<Page x:Class="DPM.UI.Views.PipelineDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">

    <Page.Resources>
        <Style x:Key="TabStyle" TargetType="TabItem">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#89B4FA"/>
                    <Setter Property="Foreground" Value="#1E1E2E"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Back"
                        Background="#45475A" Foreground="White"
                        Style="{StaticResource ActionBtn}"
                        Click="Back_Click"/>
                <StackPanel Grid.Column="1" Margin="20,0">
                    <TextBlock x:Name="PipelineNameText"
                               Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="PipelineDescText"
                               Foreground="#CDD6F4" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border x:Name="StatusBadge" CornerRadius="12"
                            Padding="12,4" Margin="0,0,15,0">
                        <TextBlock x:Name="StatusText" FontWeight="Bold" FontSize="12"/>
                    </Border>
                    <Button Content="▶ Run Pipeline"
                            Background="#A6E3A1" Foreground="#1E1E2E"
                            Style="{StaticResource ActionBtn}"
                            Click="RunPipeline_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="#1E1E2E" BorderThickness="0">

            <!-- ═══════════════ TAB 1 : DATA ═══════════════ -->
            <TabItem Header="📊 Data" Style="{StaticResource TabStyle}">
                <ScrollViewer Background="#1E1E2E">
                    <StackPanel Margin="20">

                        <!-- Data Sources -->
                        <TextBlock Text="Data Sources" Foreground="White"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <DataGrid x:Name="DataSourcesGrid"
                                  AutoGenerateColumns="False"
                                  Background="#313244" Foreground="White"
                                  BorderThickness="0" RowBackground="#313244"
                                  AlternatingRowBackground="#45475A"
                                  GridLinesVisibility="None" IsReadOnly="True"
                                  Margin="0,0,0,20" MaxHeight="150">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader"
                                       BasedOn="{StaticResource DataGridHeaderStyle}"/>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                                <DataGridTextColumn Header="File / Host" Binding="{Binding FilePath}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Raw Data Preview -->
                        <TextBlock Text="Raw Data Preview (50 rows)" Foreground="White"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Button Content="🔄 Load Preview"
                                Background="#89B4FA" Foreground="#1E1E2E"
                                Style="{StaticResource ActionBtn}"
                                HorizontalAlignment="Left" Margin="0,0,0,10"
                                Click="LoadRawPreview_Click"/>
                        <DataGrid x:Name="RawDataGrid"
                                  AutoGenerateColumns="True"
                                  Background="#313244" Foreground="White"
                                  BorderThickness="0" RowBackground="#313244"
                                  AlternatingRowBackground="#45475A"
                                  GridLinesVisibility="None" IsReadOnly="True"
                                  MaxHeight="300">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader"
                                       BasedOn="{StaticResource DataGridHeaderStyle}"/>
                            </DataGrid.ColumnHeaderStyle>
                        </DataGrid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════ TAB 2 : TRANSFORM ═══════════════ -->
            <TabItem Header="⚙️ Transform" Style="{StaticResource TabStyle}">
                <Grid Background="#1E1E2E">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel — Add Transform -->
                    <Border Grid.Column="0" Background="#181825" Padding="20">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Text="Add Transform Step"
                                           Foreground="White" FontSize="16"
                                           FontWeight="Bold" Margin="0,0,0,15"/>

                                <!-- Transform Type -->
                                <TextBlock Text="Type" Foreground="#CDD6F4"
                                           FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox x:Name="TransformTypeCombo"
                                          Style="{StaticResource ComboStyle}"
                                          Margin="0,0,0,15"
                                          SelectionChanged="TransformType_Changed">
                                    <ComboBox.Resources>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Background" Value="#45475A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Style>
                                    </ComboBox.Resources>
                                    <ComboBoxItem Content="🔍 Filter (Where)" Tag="Filter"/>
                                    <ComboBoxItem Content="📋 Select Columns" Tag="SelectColumns"/>
                                    <ComboBoxItem Content="↑ OrderBy ASC" Tag="OrderBy"/>
                                    <ComboBoxItem Content="↓ OrderBy DESC" Tag="OrderByDescending"/>
                                    <ComboBoxItem Content="📦 GroupBy + Aggregate" Tag="GroupBy"/>
                                    <ComboBoxItem Content="🧹 Remove Nulls/Empty" Tag="RemoveNulls"/>
                                    <ComboBoxItem Content="✂️ Trim Spaces" Tag="TrimSpaces"/>
                                    <ComboBoxItem Content="🔄 Replace Value" Tag="ReplaceValue"/>
                                    <ComboBoxItem Content="🔢 Change Type" Tag="ChangeType"/>
                                </ComboBox>

                                <!-- Filter Panel -->
                                <StackPanel x:Name="FilterPanel" Visibility="Collapsed">
                                    <TextBlock Text="Column" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="FilterColumn" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Operator" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="FilterOp" Style="{StaticResource ComboStyle}" Margin="0,0,0,10">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#45475A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="==" Tag="=="/>
                                        <ComboBoxItem Content="!=" Tag="!="/>
                                        <ComboBoxItem Content="contains" Tag="contains"/>
                                        <ComboBoxItem Content=">" Tag=">"/>
                                        <ComboBoxItem Content="&lt;" Tag="&lt;"/>
                                        <ComboBoxItem Content=">=" Tag=">="/>
                                        <ComboBoxItem Content="&lt;=" Tag="&lt;="/>
                                    </ComboBox>
                                    <TextBlock Text="Value" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="FilterValue" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                </StackPanel>

                                <!-- Select Columns Panel -->
                                <StackPanel x:Name="SelectColumnsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Columns (comma separated)" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SelectColumnsBox" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                </StackPanel>

                                <!-- OrderBy Panel -->
                                <StackPanel x:Name="OrderByPanel" Visibility="Collapsed">
                                    <TextBlock Text="Column" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="OrderByColumn" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                </StackPanel>

                                <!-- GroupBy Panel -->
                                <StackPanel x:Name="GroupByPanel" Visibility="Collapsed">
                                    <TextBlock Text="Group Column" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="GroupByColumn" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Aggregate Column" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="AggColumn" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Function" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="AggFunc" Style="{StaticResource ComboStyle}" Margin="0,0,0,10">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#45475A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="SUM" Tag="SUM"/>
                                        <ComboBoxItem Content="AVG" Tag="AVG"/>
                                        <ComboBoxItem Content="COUNT" Tag="COUNT"/>
                                        <ComboBoxItem Content="MIN" Tag="MIN"/>
                                        <ComboBoxItem Content="MAX" Tag="MAX"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Replace Panel -->
                                <StackPanel x:Name="ReplacePanel" Visibility="Collapsed">
                                    <TextBlock Text="Column" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="ReplaceColumn" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Old Value" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="ReplaceOld" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                    <TextBlock Text="New Value" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="ReplaceNew" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                </StackPanel>

                                <!-- ChangeType Panel -->
                                <StackPanel x:Name="ChangeTypePanel" Visibility="Collapsed">
                                    <TextBlock Text="Column" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox x:Name="ChangeTypeColumn" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Target Type" Foreground="#CDD6F4" FontSize="12" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="TargetTypeCombo" Style="{StaticResource ComboStyle}" Margin="0,0,0,10">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#45475A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="string" Tag="string"/>
                                        <ComboBoxItem Content="int" Tag="int"/>
                                        <ComboBoxItem Content="double" Tag="double"/>
                                        <ComboBoxItem Content="decimal" Tag="decimal"/>
                                        <ComboBoxItem Content="datetime" Tag="datetime"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Add Button -->
                                <Button Content="➕ Add Step"
                                        Background="#89B4FA" Foreground="#1E1E2E"
                                        Style="{StaticResource ActionBtn}"
                                        Margin="0,10,0,20"
                                        Click="AddTransformStep_Click"/>

                                <!-- Steps List -->
                                <TextBlock Text="Applied Steps" Foreground="White"
                                           FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="StepsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#313244" CornerRadius="8"
                                                    Padding="12,8" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Type}"
                                                                   Foreground="#89B4FA"
                                                                   FontWeight="Bold" FontSize="12"/>
                                                        <TextBlock Text="{Binding Parameters}"
                                                                   Foreground="#CDD6F4" FontSize="11"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="✕"
                                                            Background="#F38BA8" Foreground="#1E1E2E"
                                                            FontWeight="Bold" Padding="6,4"
                                                            BorderThickness="0" Cursor="Hand"
                                                            Click="DeleteStep_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Right Panel — Transformed Preview -->
                    <StackPanel Grid.Column="1" Margin="20">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Transformed Data Preview"
                                       Foreground="White" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="1" Content="🔄 Apply &amp; Preview"
                                    Background="#CBA6F7" Foreground="#1E1E2E"
                                    Style="{StaticResource ActionBtn}"
                                    Click="ApplyTransform_Click"/>
                        </Grid>
                        <TextBlock x:Name="TransformStatsText"
                                   Foreground="#A6E3A1" FontSize="12" Margin="0,0,0,10"/>
                        <DataGrid x:Name="TransformedGrid"
                                  AutoGenerateColumns="True"
                                  Background="#313244" Foreground="White"
                                  BorderThickness="0" RowBackground="#313244"
                                  AlternatingRowBackground="#45475A"
                                  GridLinesVisibility="None" IsReadOnly="True">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader"
                                       BasedOn="{StaticResource DataGridHeaderStyle}"/>
                            </DataGrid.ColumnHeaderStyle>
                        </DataGrid>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- ═══════════════ TAB 3 : LOGS ═══════════════ -->
            <TabItem Header="📋 Logs" Style="{StaticResource TabStyle}">
                <StackPanel Margin="20" Background="#1E1E2E">
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Execution Logs" Foreground="White"
                                   FontSize="16" FontWeight="Bold"/>
                        <Button Grid.Column="1" Content="🗑 Clear Logs"
                                Background="#F38BA8" Foreground="#1E1E2E"
                                Style="{StaticResource ActionBtn}"
                                Click="ClearLogs_Click"/>
                    </Grid>
                    <DataGrid x:Name="LogsGrid"
                              AutoGenerateColumns="False"
                              Background="#313244" Foreground="White"
                              BorderThickness="0" RowBackground="#313244"
                              AlternatingRowBackground="#45475A"
                              GridLinesVisibility="None" IsReadOnly="True">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader"
                                   BasedOn="{StaticResource DataGridHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"
                                Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="100"/>
                            <DataGridTextColumn Header="Level"
                                Binding="{Binding Level}" Width="80"/>
                            <DataGridTextColumn Header="Message"
                                Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Page>